    "about.copyright" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pokémon and its trademarks are ©1995–%@ Nintendo, Creatures, and GAMEFREAK."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポケモンおよびその商標は ©1995–%@ 任天堂・クリーチャーズ・ゲームフリークに帰属します。"
          }
        }
      }
    },
    "about.fansite" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PokéJisho is an unofficial, educational Pokémon fan project, not affiliated with or endorsed by Nintendo, Creatures, or GAMEFREAK."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ポケ辞書は非公式の教育目的のポケモンファンアプリであり、任天堂・クリーチャーズ・ゲームフリークとは関係なく、公認もされていません。"
          }
        }
      }
    },
    "about.github" : {
